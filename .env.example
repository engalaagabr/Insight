# === BACKEND CONFIGURATION ===
# FastAPI Server
UVICORN_HOST=0.0.0.0
UVICORN_PORT=10000

# CORS Configuration (comma-separated domains)
# For development: http://localhost:3000
# For production: https://insight.vercel.app
CORS_ORIGINS=http://localhost:3000

# Logging Level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# === API KEYS ===
# Google Gemini API - Get from: https://console.cloud.google.com/
# 1. Create a project in Google Cloud
# 2. Enable Generative AI API
# 3. Create an API key from credentials
GOOGLE_API_KEY=your_google_gemini_api_key_here

# Alternative: OpenAI API Key - Get from: https://platform.openai.com/api-keys/
# Format: sk-...
OPENAI_API_KEY=

# Alternative: Anthropic API Key - Get from: https://console.anthropic.com/
# Format: sk-ant-...
ANTHROPIC_API_KEY=

# === FRONTEND CONFIGURATION ===
# API Base URL (backend endpoint)
# For development: http://localhost:8000
# For production: https://insight-backend.onrender.com
NEXT_PUBLIC_API_URL=http://localhost:8000
