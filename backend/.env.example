# Backend Environment Configuration
# This file serves as a template for deployment

# === LLM Provider Configuration ===
# Choose one primary LLM provider

# Google Gemini (Recommended for free tier)
GOOGLE_API_KEY=your_google_api_key_here

# OpenAI (GPT models)
OPENAI_API_KEY=

# Anthropic (Claude models)
ANTHROPIC_API_KEY=

# === CORS Configuration ===
# Comma-separated list of allowed origins
# Production example: https://insight.vercel.app,https://insight.example.com
CORS_ORIGINS=http://localhost:3000

# === Server Configuration ===
UVICORN_HOST=0.0.0.0
UVICORN_PORT=10000

# === Logging ===
LOG_LEVEL=INFO

# === File Management ===
# Maximum file size in MB (default: 50)
MAX_FILE_SIZE_MB=50

# Output directory for processed files (relative to backend/)
OUTPUT_DIR=outputs

# Auto-cleanup old files after N hours (set to 0 to disable)
CLEANUP_HOURS=24
